                <object placeholders="1" c4Name="Менеджер УК" c4Type="Person" c4Description="Сотрудник управляющей компании. Управляет данными жилого комплекса и взаимодействует с системами PropDevelopment." label="&lt;b&gt;%c4Name%&lt;/b&gt;&lt;div&gt;[%c4Type%]&lt;/div&gt;&lt;br&gt;&lt;div&gt;&lt;font style='font-size:11px'&gt;%c4Description%&lt;/font&gt;&lt;/div&gt;" id="manager_uk">
