                <object placeholders="1" c4Name="tenant-core-app" c4Type="Software System" c4Description="Бэкенд-сервис для предоставления услуг собственникам. Оркестрирует взаимодействие с партнёрскими системами." label="&lt;b&gt;%c4Name%&lt;/b&gt;&lt;div&gt;[%c4Type%]&lt;/div&gt;&lt;br&gt;&lt;div&gt;&lt;font style='font-size:11px'&gt;%c4Description%&lt;/font&gt;&lt;/div&gt;" id="tenant_core">
